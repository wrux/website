---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

export interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article class="project-card link-box">
  <div class="project-media">
    <Image
      src={project.data.image}
      alt={project.data.name}
      loading="lazy"
      decoding="async"
      widths={[320, 480, 640, 768, 1024, 1280]}
      sizes="(min-width: 1024px) 320px, (min-width: 768px) 272px, 100vw"
      class="project-image"
    />
  </div>
  <div class="project-content">
    <p class="project-title">{project.data.name}</p>
    {
      project.data.description && (
        <p class="project-description">{project.data.description}</p>
      )
    }
    {
      project.data.toolsUsed?.length > 0 && (
        <ul class="project-tools">
          {project.data.toolsUsed.map((tool) => (
            <li>{tool}</li>
          ))}
        </ul>
      )
    }
    <a
      href={project.data.href}
      target="_blank"
      rel="nofollow noreferrer"
      class="project-link link-overlay link-hover"
    >
      {project.data.href}
    </a>
  </div>
</article>
