---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';

export interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article
  class="grid group grid-cols-1 md:grid-cols-5 link-box overflow-hidden border border-dashed border-[var(--rule)] bg-[var(--panel-bg-soft)] hover:border-[var(--rule-strong)] focus-within:border-[var(--rule-strong)] transition-colors duration-300"
>
  <div
    class="col-span-1 md:col-span-2 print:hidden w-full h-auto md:w-auto md:h-full md:flex-1 aspect-video md:aspect-auto"
  >
    <Image
      src={project.data.image}
      alt={project.data.name}
      loading="lazy"
      decoding="async"
      widths={[320, 480, 640, 768, 1024, 1280]}
      sizes="(min-width: 1024px) 320px, (min-width: 768px) 272px, 100vw"
      class="block size-full object-cover border-b md:border-b-0 border-dashed md:border-r border-[var(--rule)] bg-[var(--panel-bg-soft)] group-hover:border-[var(--rule-strong)] focus-within:border-[var(--rule-strong)] transition-colors duration-300"
    />
  </div>
  <div class="col-span-1 md:col-span-3 min-w-0 flex-1 max-w-prose py-4 px-5">
    <p
      class="text-base font-semibold text-[var(--text)] group-hover:text-[var(--accent-strong)] focus-within:text-[var(--accent-strong)] transition-colors duration-300"
    >
      {project.data.name}
    </p>
    {
      project.data.description && (
        <p class="mt-2 text-sm text-[var(--text-muted)]">{project.data.description}</p>
      )
    }
    {
      project.data.toolsUsed?.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-1.5 text-[11px] uppercase tracking-wide text-[var(--accent)]">
          {project.data.toolsUsed.map((tool) => (
            <li class="rounded-full border border-[var(--rule)] bg-[rgba(126,226,196,0.08)] px-2 py-0.5">
              {tool}
            </li>
          ))}
        </ul>
      )
    }
    <a
      href={project.data.href}
      target="_blank"
      rel="nofollow noreferrer"
      class="mt-3 inline-flex link-overlay text-sm text-[var(--accent)] link-hover"
    >
      {project.data.href}
    </a>
  </div>
</article>
