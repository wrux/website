---
import Logo from '~/components/Logo.astro';
import { person } from '~/data/site';
---

<header class="terminal-panel site-header">
  <div class="header-bleed-line"></div>
  <div class="site-header-inner">
    <Logo class="site-logo terminal-glow" />
    <div class="site-heading">
      <h1>{person.name}</h1>
      <p>{person.role}</p>
    </div>
  </div>

  <div class="header-bleed-line"></div>
</header>
