---
import Layout from '~/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { education, person, professionalPortfolio } from '~/data/site';
import { Icon } from 'astro-icon/components';

const jobs = await getCollection('jobs');

const parseDate = (value: string) => {
  const [day, month, year] = value.split('-').map(Number);
  return new Date(Date.UTC(year, month - 1, day));
};

const formatMonthYear = (value: string) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(parseDate(value));

const formatISODate = (value: string) =>
  parseDate(value).toISOString().slice(0, 10);

const formatTenure = (tenure: { from: string; to: string | null }) => {
  const from = formatMonthYear(tenure.from);
  const to = tenure.to ? formatMonthYear(tenure.to) : 'Present';
  return `${from} — ${to}`;
};

const sortedJobs = [...jobs].sort((a, b) => {
  const aTo = a.data.tenure.to
    ? parseDate(a.data.tenure.to).getTime()
    : Number.POSITIVE_INFINITY;
  const bTo = b.data.tenure.to
    ? parseDate(b.data.tenure.to).getTime()
    : Number.POSITIVE_INFINITY;

  if (aTo !== bTo) {
    return bTo - aTo;
  }

  return (
    parseDate(b.data.tenure.from).getTime() -
    parseDate(a.data.tenure.from).getTime()
  );
});

const contactItems = [
  {
    label: 'Website',
    value: person.website,
    href: person.website,
    itemprop: 'url',
    microformatClass: 'u-url',
  },
  {
    label: 'Blog',
    value: person.blog,
    href: person.blog,
    itemprop: 'sameAs',
    microformatClass: 'u-url',
  },
  {
    label: 'Email',
    value: person.contact.email,
    href: person.contact.email ? `mailto:${person.contact.email}` : null,
    itemprop: 'email',
    microformatClass: 'u-email',
  },
  {
    label: 'Phone',
    value: person.contact.phone,
    href: person.contact.phone ? `tel:${person.contact.phone}` : null,
    itemprop: 'telephone',
    microformatClass: 'p-tel',
  },
  {
    label: 'LinkedIn',
    value: person.contact.linkedin,
    href: person.contact.linkedin,
    itemprop: 'sameAs',
    microformatClass: 'u-url',
  },
  {
    label: 'GitHub',
    value: person.contact.github,
    href: person.contact.github,
    itemprop: 'sameAs',
    microformatClass: 'u-url',
  },
].filter((item) => item.value);

const sameAs = [
  person.contact.linkedin,
  person.contact.github,
  person.website,
  person.blog,
].filter(Boolean);

const cvStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: person.name,
  jobTitle: person.role,
  description: person.summary,
  url: person.website,
  email: person.contact.email || undefined,
  telephone: person.contact.phone || undefined,
  address: {
    '@type': 'PostalAddress',
    addressLocality: person.location,
  },
  sameAs,
  knowsAbout: person.skills,
  alumniOf: education.map((school) => ({
    '@type': 'CollegeOrUniversity',
    name: school.institution,
    address: school.location,
  })),
  hasOccupation: {
    '@type': 'Occupation',
    name: person.role,
    skills: person.skills,
  },
  workExample: professionalPortfolio.map((project) => ({
    '@type': 'CreativeWork',
    name: project.name,
    alternateName: project.subtitle,
    description: project.description,
    url: project.urls[0]?.href,
    sameAs: project.urls.map((url) => url.href),
    keywords: project.skills,
  })),
  workExperience: sortedJobs.map((job) => ({
    '@type': 'Role',
    roleName: job.data.title,
    description: job.data.description?.join(' '),
    startDate: formatISODate(job.data.tenure.from),
    endDate: job.data.tenure.to ? formatISODate(job.data.tenure.to) : undefined,
    worksFor: {
      '@type': 'Organization',
      name: job.data.company,
      address: job.data.location,
    },
  })),
};

const cvStructuredDataJson = JSON.stringify(cvStructuredData).replace(
  /</g,
  '\\u003c',
);
---

<Layout
  title={`CV | ${person.name}`}
  description={`Professional CV for ${person.name}, ${person.role}.`}
>
  <script type="application/ld+json" set:html={cvStructuredDataJson} />

  <article
    class="cv-document h-card space-y-8"
    itemscope
    itemtype="https://schema.org/Person"
  >
    <section
      class="cv-print-section terminal-card p-6"
      aria-label="CV contact details"
    >
      <h2
        class="flex items-center gap-2 text-lg font-semibold text-[var(--text)]"
      >
        <Icon
          name="lucide:contact"
          size={20}
          class="text-[var(--accent)] print:text-black"
        />
        Contact
      </h2>
      <div
        class="cv-contact-list mt-4 grid gap-3 text-sm text-[var(--text-muted)] sm:grid-cols-2"
      >
        <p>
          <span class="font-medium text-[var(--accent)]">Name</span>
          <span class="p-name block" itemprop="name">{person.name}</span>
        </p>
        <p>
          <span class="font-medium text-[var(--accent)]">Role</span>
          <span class="p-job-title block" itemprop="jobTitle">{person.role}</span>
        </p>
        <p>
          <span class="font-medium text-[var(--accent)]">Location</span>
          <span
            class="block"
            itemprop="address"
            itemscope
            itemtype="https://schema.org/PostalAddress"
          >
            <span class="p-locality" itemprop="addressLocality"
              >{person.location}</span
            >
          </span>
        </p>
        {
          contactItems.map((item) => (
            <p>
              <span class="font-medium text-[var(--accent)]">{item.label}</span>
              <a
                class:list={[
                  'cv-print-visible-url block link-hover text-[var(--accent)] break-all sm:break-normal',
                  item.microformatClass,
                ]}
                href={item.href ?? undefined}
                itemprop={item.itemprop}
              >
                {item.value}
              </a>
            </p>
          ))
        }
      </div>
    </section>

    <section class="cv-print-page space-y-8">
      <div class="cv-print-section terminal-card p-6">
        <h2
          class="flex items-center gap-2 text-lg font-semibold text-[var(--text)]"
        >
          <Icon
            name="lucide:file-text"
            size={20}
            class="text-[var(--accent)] print:text-black"
          />
          Professional Summary
        </h2>
        <div class="cv-summary-content max-w-prose">
          <p class="mt-3 text-base leading-relaxed text-[var(--text-muted)]">
            {person.summary}
          </p>
          <p class="mt-4 text-base leading-relaxed text-[var(--text-muted)]">
            {person.bio.split('callum.co.uk')[0]} on
            <a href="https://callum.co.uk" target="_blank" class="link-underline"
              >callum.co.uk</a
            >.
          </p>
        </div>
      </div>

      <div class="cv-print-section terminal-card p-6">
        <h2
          class="flex items-center gap-2 text-lg font-semibold text-[var(--text)]"
        >
          <Icon
            name="lucide:sparkles"
            size={20}
            class="text-[var(--accent)] print:text-black"
          />
          Technical Skills
        </h2>
        <p
          class="cv-print-only cv-print-line mt-5 text-sm text-[var(--text-muted)]"
          aria-label="Technical skills for resume parsing"
        >
          Technical Skills: {person.skills.join(', ')}
        </p>
        <ul
          class="cv-print-hide mt-5 flex flex-wrap gap-2 text-sm text-[var(--accent)]"
          aria-label="Core software engineering skills"
        >
          {
            person.skills.map((skill) => (
              <li
                class="rounded-full border border-[var(--rule)] bg-[rgba(126,226,196,0.08)] px-2 py-0.5"
                itemprop="knowsAbout"
              >
                {skill}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="cv-print-section terminal-card p-6">
        <h2
          class="flex items-center gap-2 text-lg font-semibold text-[var(--text)]"
        >
          <Icon
            name="lucide:briefcase"
            size={20}
            class="text-[var(--accent)] print:text-black"
          />
          Work Experience
        </h2>
        <ul class="mt-6 flex flex-col gap-5">
          {
            sortedJobs.map((job) => (
              <li class="terminal-item">
                <h3 class="text-base font-semibold text-[var(--text)]">
                  {job.data.title}
                </h3>
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <p class="text-sm text-[var(--text-muted)]">
                    {job.data.company} · {job.data.location}
                  </p>
                  <p class="text-sm text-[var(--accent)]">
                    {formatTenure(job.data.tenure)}
                  </p>
                </div>
                {
                  job.data.description && (
                    <ul class="mt-3 max-w-prose list-disc space-y-2 pl-5 text-sm text-[var(--text-muted)]">
                      {job.data.description.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  )
                }
              </li>
            ))
          }
        </ul>
      </div>

      <div class="cv-print-section terminal-card p-6">
        <h2
          class="flex items-center gap-2 text-lg font-semibold text-[var(--text)]"
        >
          <Icon
            name="lucide:graduation-cap"
            size={20}
            class="text-[var(--accent)] print:text-black"
          />
          Education
        </h2>
        <ul class="mt-6 flex flex-col gap-5">
          {
            education.map((school) => (
              <li class="terminal-item">
                <h3 class="text-base font-semibold text-[var(--text)]">
                  {school.degree}
                </h3>
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                  <p class="text-sm text-[var(--text-muted)]">
                    {school.institution} · {school.location}
                  </p>
                  <p class="text-sm text-[var(--accent)]">{school.period}</p>
                </div>
                <p class="mt-3 text-sm text-[var(--text-muted)]">{school.summary}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <aside class="cv-print-page space-y-8">
      <section class="cv-print-section cv-print-flow terminal-card p-6">
        <h2
          class="flex items-center gap-2 text-lg font-semibold text-[var(--text)]"
        >
          <Icon
            name="lucide:folder-git-2"
            size={20}
            class="text-[var(--accent)] print:text-black"
          />
          Professional Portfolio
        </h2>
        <ul class="cv-portfolio-list mt-5 flex flex-col gap-4">
          {
            professionalPortfolio.map((project) => (
              <li
                class="cv-portfolio-item terminal-item"
                itemprop="workExample"
                itemscope
                itemtype="https://schema.org/CreativeWork"
              >
                <div class="cv-portfolio-heading">
                  <h3
                    class="text-base font-semibold text-[var(--text)]"
                    itemprop="name"
                  >
                    {project.name}
                  </h3>
                  {
                    project.subtitle && (
                      <p class="mt-1 text-sm font-medium text-[var(--text-muted)]">
                        {project.subtitle}
                      </p>
                    )
                  }
                  <ul
                    class="cv-portfolio-tags cv-print-hide mt-3 flex flex-wrap gap-1.5 text-[11px] uppercase tracking-wide text-[var(--accent)]"
                    aria-label={`${project.name} project skills`}
                  >
                    {project.skills.map((skill) => (
                      <li>{skill}</li>
                    ))}
                  </ul>
                  <p class="cv-print-only cv-print-line cv-portfolio-skills-csv">
                    Skills: {project.skills.join(', ')}
                  </p>
                </div>
                <div class="cv-portfolio-body">
                  <p
                    class="mt-2 text-sm text-[var(--text-muted)]"
                    itemprop="description"
                  >
                    {project.description}
                  </p>
                  <ul
                    class="cv-portfolio-links mt-3 flex flex-wrap gap-2 text-sm text-[var(--accent)]"
                  >
                    {project.urls.map((url) => (
                      <li>
                        <a
                          href={url.href}
                          target="_blank"
                          rel="nofollow noreferrer"
                          class="cv-print-visible-url link-hover text-[var(--accent)] break-all sm:break-normal"
                          itemprop="url"
                        >
                          <span class="cv-screen-only">{url.label}</span>
                          <span class="cv-print-only">{url.href}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>
  </article>
</Layout>
