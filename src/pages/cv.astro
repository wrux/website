---
import Layout from '~/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { person, professionalPortfolio } from '~/data/site';
import { Icon } from 'astro-icon/components';

const jobs = await getCollection('jobs');

const parseDate = (value: string) => {
  const [day, month, year] = value.split('-').map(Number);
  return new Date(Date.UTC(year, month - 1, day));
};

const formatMonthYear = (value: string) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(parseDate(value));

const formatISODate = (value: string) =>
  parseDate(value).toISOString().slice(0, 10);

const formatTenure = (tenure: { from: string; to: string | null }) => {
  const from = formatMonthYear(tenure.from);
  const to = tenure.to ? formatMonthYear(tenure.to) : 'Present';
  return `${from} — ${to}`;
};

const sortedJobs = [...jobs].sort((a, b) => {
  const aTo = a.data.tenure.to
    ? parseDate(a.data.tenure.to).getTime()
    : Number.POSITIVE_INFINITY;
  const bTo = b.data.tenure.to
    ? parseDate(b.data.tenure.to).getTime()
    : Number.POSITIVE_INFINITY;

  if (aTo !== bTo) {
    return bTo - aTo;
  }

  return (
    parseDate(b.data.tenure.from).getTime() -
    parseDate(a.data.tenure.from).getTime()
  );
});

const contactItems = [
  {
    label: 'Email',
    value: person.contact.email,
    href: person.contact.email ? `mailto:${person.contact.email}` : null,
    itemprop: 'email',
    microformatClass: 'u-email',
  },
  {
    label: 'Phone',
    value: person.contact.phone,
    href: person.contact.phone ? `tel:${person.contact.phone}` : null,
    itemprop: 'telephone',
    microformatClass: 'p-tel',
  },
  {
    label: 'LinkedIn',
    value: person.contact.linkedin,
    href: person.contact.linkedin,
    itemprop: 'sameAs',
    microformatClass: 'u-url',
  },
  {
    label: 'GitHub',
    value: person.contact.github,
    href: person.contact.github,
    itemprop: 'sameAs',
    microformatClass: 'u-url',
  },
].filter((item) => item.value);

const sameAs = [
  person.contact.linkedin,
  person.contact.github,
  person.website,
].filter(Boolean);

const cvStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: person.name,
  jobTitle: person.role,
  description: person.summary,
  url: person.website,
  email: person.contact.email || undefined,
  telephone: person.contact.phone || undefined,
  address: {
    '@type': 'PostalAddress',
    addressLocality: person.location,
  },
  sameAs,
  knowsAbout: person.skills,
  hasOccupation: {
    '@type': 'Occupation',
    name: person.role,
    skills: person.skills,
  },
  workExample: professionalPortfolio.map((project) => ({
    '@type': 'CreativeWork',
    name: project.name,
    alternateName: project.subtitle,
    description: project.description,
    url: project.urls[0]?.href,
    sameAs: project.urls.map((url) => url.href),
    keywords: project.skills ?? project.keywords,
  })),
  workExperience: sortedJobs.map((job) => ({
    '@type': 'Role',
    roleName: job.data.title,
    startDate: formatISODate(job.data.tenure.from),
    endDate: job.data.tenure.to ? formatISODate(job.data.tenure.to) : undefined,
    worksFor: {
      '@type': 'Organization',
      name: job.data.company,
      address: job.data.location,
    },
  })),
};

const cvStructuredDataJson = JSON.stringify(cvStructuredData).replace(
  /</g,
  '\\u003c',
);
---

<Layout
  title={`CV | ${person.name}`}
  description={`Professional CV for ${person.name}, ${person.role}.`}
>
  <script type="application/ld+json" set:html={cvStructuredDataJson} />

  <article
    class="cv-document h-card"
    itemscope
    itemtype="https://schema.org/Person"
  >
    <section class="cv-section terminal-card" aria-label="CV contact details">
      <h2 class="section-title">
        <Icon name="lucide:contact" size={20} class="section-icon" />
        Contact
      </h2>
      <div class="cv-contact-list">
        <p>
          <span class="field-label">Name</span>
          <span class="field-value p-name" itemprop="name">{person.name}</span>
        </p>
        <p>
          <span class="field-label">Role</span>
          <span class="field-value p-job-title" itemprop="jobTitle"
            >{person.role}</span
          >
        </p>
        <p>
          <span class="field-label">Location</span>
          <span
            class="field-value"
            itemprop="address"
            itemscope
            itemtype="https://schema.org/PostalAddress"
          >
            <span class="p-locality" itemprop="addressLocality"
              >{person.location}</span
            >
          </span>
        </p>
        {
          contactItems.map((item) => (
            <p>
              <span class="field-label">{item.label}</span>
              <a
                class:list={[
                  'cv-print-visible-url field-value link-hover text-link',
                  item.microformatClass,
                ]}
                href={item.href ?? undefined}
                itemprop={item.itemprop}
              >
                {item.value}
              </a>
            </p>
          ))
        }
      </div>
    </section>

    <section class="cv-print-page cv-stack">
      <div class="cv-section terminal-card">
        <h2 class="section-title">
          <Icon name="lucide:file-text" size={20} class="section-icon" />
          Professional Summary
        </h2>
        <div class="cv-summary-content prose">
          <p>{person.summary}</p>
          <p>
            {person.bio.split('callum.co.uk')[0]} on
            <a href="https://callum.co.uk" target="_blank" class="link-underline"
              >callum.co.uk</a
            >.
          </p>
        </div>
      </div>

      <div class="cv-section terminal-card">
        <h2 class="section-title">
          <Icon name="lucide:sparkles" size={20} class="section-icon" />
          Technical Skills
        </h2>
        <p
          class="cv-print-only cv-print-line"
          aria-label="Technical skills for resume parsing"
        >
          Technical Skills: {person.skills.join(', ')}
        </p>
        <ul
          class="cv-print-hide skill-list"
          aria-label="Core software engineering skills"
        >
          {
            person.skills.map((skill) => (
              <li class="skill-chip" itemprop="knowsAbout">
                {skill}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="cv-section terminal-card">
        <h2 class="section-title">
          <Icon name="lucide:briefcase" size={20} class="section-icon" />
          Work Experience
        </h2>
        <ul class="work-list">
          {
            sortedJobs.map((job) => (
              <li class="terminal-item">
                <h3>{job.data.title}</h3>
                <div class="work-meta">
                  <p>
                    {job.data.company} · {job.data.location}
                  </p>
                  <p>{formatTenure(job.data.tenure)}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <aside class="cv-print-page cv-stack">
      <section class="cv-section cv-print-flow terminal-card">
        <h2 class="section-title">
          <Icon name="lucide:folder-git-2" size={20} class="section-icon" />
          Professional Portfolio
        </h2>
        <ul class="cv-portfolio-list">
          {
            professionalPortfolio.map((project) => (
              <li
                class="cv-portfolio-item terminal-item"
                itemprop="workExample"
                itemscope
                itemtype="https://schema.org/CreativeWork"
              >
                <div class="cv-portfolio-heading">
                  <h3 itemprop="name">
                    {project.name}
                  </h3>
                  {
                    project.subtitle && (
                      <p class="cv-portfolio-subtitle">{project.subtitle}</p>
                    )
                  }
                  <ul
                    class="cv-portfolio-tags cv-print-hide"
                    aria-label={`${project.name} project skills`}
                  >
                    {(project.skills ?? project.keywords).map((skill) => (
                      <li>{skill}</li>
                    ))}
                  </ul>
                  <p class="cv-print-only cv-print-line cv-portfolio-skills-csv">
                    Skills: {(project.skills ?? project.keywords).join(', ')}
                  </p>
                </div>
                <div class="cv-portfolio-body">
                  <p itemprop="description">
                    {project.description}
                  </p>
                  <ul class="cv-portfolio-links">
                    {project.urls.map((url) => (
                      <li>
                        <a
                          href={url.href}
                          target="_blank"
                          rel="nofollow noreferrer"
                          class="cv-print-visible-url link-hover text-link"
                          itemprop="url"
                        >
                          <span class="cv-screen-only">{url.label}</span>
                          <span class="cv-print-only">{url.href}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>
  </article>
</Layout>
