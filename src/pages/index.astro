---
import Layout from '~/layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
import SocialIcon from '~/components/SocialIcon.astro';
import ProjectIcon from '~/components/ProjectIcon.astro';
import { person, socialLinks, featuredProjects } from '~/data/site';
---

<Layout
  title="Software Engineer & Freelancer Building Digital Products | wrux.com"
  description="Software engineer and freelancer building digital products, including my own project Kacet. Focused on clean code, thoughtful design, and practical solutions."
>
  <section class="space-y-8">
    <div
      class="terminal-card p-6 border-b-0 border-l-0 border-r-0 rounded-none"
    >
      <h2
        class="flex items-center gap-2 text-lg font-semibold text-emerald-100"
      >
        <Icon name="lucide:file-text" size={20} class="terminal-icon" />
        Summary
      </h2>
      <div class="max-w-prose">
        <p class="mt-3 text-base leading-relaxed text-emerald-200">
          {person.summary}
        </p>
        <p class="mt-4 text-base leading-relaxed text-emerald-200">
          {person.bio.split('callum.co.uk')[0]} on
          <a href="https://callum.co.uk" target="_blank" class="link-underline"
            >callum.co.uk</a
          >.
        </p>
      </div>
    </div>

    <div
      class="terminal-card p-6 border-t-0 border-l-0 border-r-0 rounded-none"
    >
      <h2
        class="flex items-center gap-2 text-lg font-semibold text-emerald-100"
      >
        <Icon name="lucide:folder-git-2" size={20} class="terminal-icon" />
        Personal Projects
      </h2>
      <p class="mt-2 flex items-center gap-2 text-sm text-emerald-300">
        A selection of personal projects I've been working on.
      </p>
      <ul class="mt-6 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6">
        {
          featuredProjects.map((project) => (
            <li class="group relative link-box flex flex-col gap-3 terminal-item">
              <div class="octagon relative aspect-square w-full rotate-[30deg] overflow-hidden group-hover:rotate-[10deg] transition-transform duration-300">
                <div
                  class="relative aspect-square overflow-hidden h-full w-full flex items-center justify-center"
                  style={`background-color: ${project.color};`}
                >
                  <ProjectIcon
                    name={project.name}
                    size={48}
                    class="-rotate-[30deg] group-hover:-rotate-[10deg] transition-transform duration-300 group-hover:scale-110"
                  />
                </div>
              </div>
              <a
                href={project.href}
                target="_blank"
                rel="nofollow noreferrer"
                class="link-overlay link-hover text-emerald-200 text-center text-sm inline-flex items-center justify-center gap-1"
                aria-label={project.label}
              >
                {project.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <aside>
    <div
      class="terminal-card p-6 border-l-0 border-r-0 rounded-none lg:border-l"
    >
      <h2
        class="flex items-center gap-2 text-lg font-semibold text-emerald-100"
      >
        <Icon name="lucide:globe" size={20} class="terminal-icon" />
        Online
      </h2>
      <ul class="mt-4 flex flex-col gap-3 text-sm text-emerald-300">
        {
          socialLinks.map((link) => (
            <li class="flex items-center justify-between gap-3">
              <span class="flex items-center gap-2">
                <SocialIcon
                  name={link.name}
                  size={16}
                  class="terminal-icon shrink-0"
                />
                {link.label}
              </span>
              <a
                href={link.href}
                target="_blank"
                rel="nofollow noreferrer"
                class="link-hover text-emerald-200 flex items-center gap-1.5 truncate min-w-0 justify-end"
                title={link.href}
              >
                <span class="truncate">{link.href}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </aside>
</Layout>
